generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categories {
  category_id   Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  category_name String    @unique(map: "categories_unique") @db.VarChar(100)
  color         String    @db.VarChar(10)
  created_at    DateTime? @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)
  icon          String?   @db.VarChar(50)
  tickets       tickets[]
}

model divisions {
  division_id   Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  division_name String    @unique(map: "divisions_unique") @db.VarChar(100)
  created_at    DateTime  @default(now()) @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)
  deleted_at    DateTime? @db.DateTime(0)
  tickets       tickets[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model roles {
  role_id     Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  role_name   String    @unique(map: "roles_unique") @db.VarChar(60)
  permissions String?   @db.LongText
  description String?   @db.Text
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  users       users[]
}

model ticket_documents {
  ticket_document_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  ticket_id          BigInt    @db.UnsignedBigInt
  // Legacy column (kept for backward-compatible migrations)
  file_name          String?   @db.VarChar(255)
  // New columns for secure storage
  original_name      String?   @db.VarChar(255)
  storage_name       String?   @unique(map: "ticket_documents_storage_unique") @db.VarChar(255)
  file_path          String    @db.VarChar(500)
  file_size          Int?
  file_extension     String?   @db.VarChar(10)
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  tickets            tickets   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade, onUpdate: NoAction, map: "ticket_documents_tickets_FK")

  @@index([ticket_id], map: "ticket_documents_tickets_FK")
}

model ticket_priorities {
  ticket_priority_id   Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  ticket_priority_name String    @unique(map: "ticket_priorities_unique") @db.VarChar(100)
  color                String?   @db.VarChar(100)
  icon                 String?   @db.VarChar(50)
  is_default           Boolean?  @default(false)
  created_at           DateTime  @default(now()) @db.DateTime(0)
  updated_at           DateTime? @db.DateTime(0)
  deleted_at           DateTime? @db.DateTime(0)
  tickets              tickets[]
}

model ticket_reply_documents {
  ticket_reply_document_id BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  ticket_reply_id          BigInt    @db.UnsignedBigInt
  // Legacy column (kept for backward-compatible migrations)
  file_name                String?   @db.VarChar(255)
  // New columns for secure storage
  original_name            String?   @db.VarChar(255)
  storage_name             String?   @unique(map: "ticket_reply_documents_storage_unique") @db.VarChar(255)
  file_path                String    @db.VarChar(500)
  file_size                Int?
  file_extension           String?   @db.VarChar(10)
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
  ticket_replys            ticket_replys @relation(fields: [ticket_reply_id], references: [ticket_reply_id], onDelete: Cascade, onUpdate: NoAction, map: "ticket_reply_documents_reply_FK")

  @@index([ticket_reply_id], map: "ticket_reply_documents_reply_FK")
}

model ticket_replys {
  ticket_reply_id  BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  ticket_id        BigInt                     @db.UnsignedBigInt
  ticket_status_id Int                        @db.UnsignedTinyInt
  pic_user_id      BigInt                     @db.UnsignedBigInt
  reply_description String?                   @db.LongText
  ticket_attch     ticket_replys_ticket_attch @default(N)
  created_at       DateTime?                  @db.DateTime(0)
  ticket_statuses  ticket_statuses            @relation(fields: [ticket_status_id], references: [ticket_status_id], onUpdate: Restrict, map: "ticket_replys_ticket_statuses_FK")
  tickets          tickets                    @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade, onUpdate: Restrict, map: "ticket_replys_tickets_FK")
  users            users                      @relation(fields: [pic_user_id], references: [user_id], onUpdate: Restrict, map: "ticket_replys_users_FK")
  ticket_reply_documents ticket_reply_documents[]

  @@index([ticket_status_id], map: "ticket_replys_ticket_statuses_FK")
  @@index([ticket_id], map: "ticket_replys_tickets_FK")
  @@index([pic_user_id], map: "ticket_replys_users_FK")
}

model ticket_statuses {
  ticket_status_id Int             @id @default(autoincrement()) @db.UnsignedTinyInt
  ticket_name      String          @unique(map: "ticket_statuses_unique") @db.VarChar(255)
  color            String          @default("#cecece") @db.VarChar(255)
  is_default       Boolean         @default(false)
  deleted_at       DateTime?       @db.Timestamp(0)
  created_at       DateTime?       @db.Timestamp(0)
  updated_at       DateTime?       @db.Timestamp(0)
  ticket_replys    ticket_replys[]
  tickets          tickets[]
}

model ticket_types {
  ticket_type_id   Int       @id @default(autoincrement()) @db.UnsignedTinyInt
  ticket_type_name String    @unique(map: "ticket_types_unique") @db.VarChar(100)
  created_at       DateTime  @default(now()) @db.DateTime(0)
  updated_at       DateTime? @db.DateTime(0)
  deleted_at       String?   @db.VarChar(100)
  tickets          tickets[]
}

model tickets {
  ticket_id                            BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  ticket_number                        String                   @unique(map: "tickets_unique") @db.VarChar(180)
  ticket_subject                       String                   @db.VarChar(250)
  ticket_detail                        String?                  @db.LongText
  requestor_name                       String                   @db.VarChar(150)
  ticket_type_id                       Int                      @db.UnsignedTinyInt
  category_id                          Int                      @db.UnsignedTinyInt
  division_id                          Int                      @db.UnsignedTinyInt
  ticket_priority_id                   Int                      @db.UnsignedTinyInt
  ticket_status_id                     Int                      @db.UnsignedTinyInt
  ticket_attach                        tickets_ticket_attach    @default(N)
  ticket_start_date                    DateTime?                @db.DateTime(0)
  ticket_end_date                      DateTime?                @db.DateTime(0)
  created_user_id                      BigInt                   @db.UnsignedBigInt
  created_at                           DateTime?                @db.DateTime(0)
  updated_user_id                      BigInt?                  @db.UnsignedBigInt
  updated_at                           DateTime?                @db.DateTime(0)
  deleted_at                           DateTime?                @db.DateTime(0)
  ticket_documents                     ticket_documents[]
  ticket_replys                        ticket_replys[]
  categories                           categories               @relation(fields: [category_id], references: [category_id], onUpdate: Restrict, map: "tickets_categories_FK")
  divisions                            divisions                @relation(fields: [division_id], references: [division_id], onUpdate: Restrict, map: "tickets_divisions_FK")
  ticket_priorities                    ticket_priorities        @relation(fields: [ticket_priority_id], references: [ticket_priority_id], onUpdate: Restrict, map: "tickets_ticket_priorities_FK")
  ticket_statuses                      ticket_statuses          @relation(fields: [ticket_status_id], references: [ticket_status_id], onUpdate: Restrict, map: "tickets_ticket_statuses_FK")
  ticket_types                         ticket_types             @relation(fields: [ticket_type_id], references: [ticket_type_id], onUpdate: Restrict, map: "tickets_ticket_types_FK")
  users_tickets_created_user_idTousers users                    @relation("tickets_created_user_idTousers", fields: [created_user_id], references: [user_id], onUpdate: Restrict, map: "tickets_users_created_FK")
  users_tickets_updated_user_idTousers users?                   @relation("tickets_updated_user_idTousers", fields: [updated_user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "tickets_users_updated_FK")

  @@index([category_id], map: "tickets_categories_FK")
  @@index([created_user_id], map: "tickets_created_users_FK")
  @@index([division_id], map: "tickets_divisions_FK")
  @@index([ticket_priority_id], map: "tickets_ticket_priorities_FK")
  @@index([ticket_status_id], map: "tickets_ticket_statuses_FK")
  @@index([ticket_type_id], map: "tickets_ticket_types_FK")
  @@index([updated_user_id], map: "tickets_updated_users_FK")
}

model users {
  user_id                                BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  user_name                              String          @unique(map: "users_unique") @db.VarChar(80)
  full_name                              String          @db.VarChar(150)
  email                                  String          @db.VarChar(150)
  password                               String          @db.Text
  role_id                                Int             @db.UnsignedTinyInt
  is_active                              Boolean         @default(true)
  verify_token                           String?         @db.Text
  verify_token_hash                      String?         @db.Text
  verify_token_expires_at                DateTime?       @db.DateTime(0)
  login_at                               DateTime?       @db.DateTime(0)
  logout_at                              DateTime?       @db.DateTime(0)
  created_at                             DateTime        @default(now()) @db.DateTime(0)
  updated_at                             DateTime?       @db.DateTime(0)
  ticket_replys                          ticket_replys[]
  tickets_tickets_created_user_idTousers tickets[]       @relation("tickets_created_user_idTousers")
  tickets_tickets_updated_user_idTousers tickets[]       @relation("tickets_updated_user_idTousers")
  roles                                  roles           @relation(fields: [role_id], references: [role_id], onUpdate: Restrict, map: "users_roles_FK")

  @@index([role_id], map: "users_roles_FK")
}

enum ticket_replys_ticket_attch {
  Y
  N
}

enum tickets_ticket_attach {
  Y
  N
}
